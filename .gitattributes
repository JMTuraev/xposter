# Matn fayllar uchun avtomatik normalizatsiya (repoda LF saqlanadi)
* text=auto eol=lf

# Windows skriptlari CRLF bo'lib qolsin
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Unix skriptlari
*.sh      text eol=lf
gradlew   text eol=lf

# Binar fayllar
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.woff  binary
*.woff2 binary
*.jks  binary
*.keystore binary
*.apk  binary
*.aab  binary
*.jar  binary
*.zip  binary
*.pdf  binary

# GitHub linguist: build/generated fayllarni statistikadan chiqarish
pubspec.lock       linguist-generated=true
functions/package-lock.json linguist-generated=true
