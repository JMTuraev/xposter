rules_version = '2';

// Buxoro POS — RBAC Security Rules (BACKEND-TAYYORGARLIK.md §3, §9, §12).
// Multi-tenant: owners/{uid}, cafes/{cafeId}, cafes/{cafeId}/{employees,...}.
// Rollar (§3): Владелец, Управляющий, Администратор зала, Официант, Повар, Маркетолог.
//
// 1.0.8: OBUNA GATE (billing) — `subActive()`. Muddat SERVER vaqtida
// (`request.time`) tekshiriladi: kassa kompyuterining kalendar'ini buzish
// hech narsa bermaydi. paidUntil/trialUntil/createdAt FAQAT Admin SDK yozadi.
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yordamchi funksiyalar ──
    function signedIn() {
      return request.auth != null;
    }
    function cafeDoc(cafeId) {
      return get(/databases/$(database)/documents/cafes/$(cafeId)).data;
    }
    function isOwner(cafeId) {
      return signedIn() && cafeDoc(cafeId).ownerUid == request.auth.uid;
    }
    function isMember(cafeId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/cafes/$(cafeId)/employees/$(request.auth.uid));
    }
    function role(cafeId) {
      return get(/databases/$(database)/documents/cafes/$(cafeId)/employees/$(request.auth.uid)).data.role;
    }
    function hasRole(cafeId, roles) {
      return isMember(cafeId) && (role(cafeId) in roles);
    }
    // Modul-darajali yozuv huquqlari (§3 rolePermissions).
    function canManage(cafeId) { // owner + Управляющий (deyarli 'all')
      return isOwner(cafeId) || hasRole(cafeId, ['Управляющий']);
    }
    function canMenu(cafeId) {    // menu: owner, manager, Повар
      return canManage(cafeId) || hasRole(cafeId, ['Повар']);
    }
    function canStock(cafeId) {   // sklad: owner, manager, Повар, Администратор зала
      return canManage(cafeId) || hasRole(cafeId, ['Повар', 'Администратор зала']);
    }
    function canSell(cafeId) {    // kassa/receipts: owner, manager, hallAdmin, Официант
      return canManage(cafeId) || hasRole(cafeId, ['Администратор зала', 'Официант']);
    }
    function canFinance(cafeId) { // finance: owner, manager
      return canManage(cafeId);
    }
    function canMarket(cafeId) {  // marketing/clients: owner, manager, Маркетолог, Официант
      return canManage(cafeId) || hasRole(cafeId, ['Маркетолог', 'Официант']);
    }
    // Yangilashda o'zgarmasligi shart bo'lgan maydonlar to'plami.
    function unchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }
    // «Код заведения» faqat BIR MARTA (bo'sh bo'lganda) yoziladi.
    function codeAssignable() {
      return !('code' in resource.data)
          || resource.data.code == null
          || resource.data.code == '';
    }

    // ── OBUNA GATE (1.0.8, Y-8/billing) ──
    // Faol = to'lov (paidUntil) YOKI sinov tugamagan. Sinov: trialUntil,
    // bo'lmasa createdAt + 7 kun (604800000 ms). request.time = SERVER vaqti.
    // Legacy: uchala maydon ham yo'q (migratsiyagacha yaratilgan kafe) — ruxsat;
    // yangi kafe yaratishda `createdAt` majburiy, shuning uchun bu teshik emas.
    function subActive(cafeId) {
      let c = cafeDoc(cafeId);
      return request.time < c.get('paidUntil', timestamp.date(1970, 1, 1))
          || request.time < c.get('trialUntil', timestamp.date(1970, 1, 1))
          || (('createdAt' in c) && c.createdAt is timestamp
              && request.time < timestamp.value(c.createdAt.toMillis() + 604800000))
          || (!('createdAt' in c) && !('paidUntil' in c) && !('trialUntil' in c));
    }

    // ── owners ──
    match /owners/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // ── Ilova konfiguratsiyasi (versiya e'loni, ichki update) ──
    // O'qish ochiq (login ekranida ham kerak bo'lishi mumkin); yozish — faqat
    // Admin SDK (`_sub_admin.js release ...`).
    match /appConfig/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Collection-group: xodim o'z hujjatini uid bo'yicha topadi (login) ──
    match /{path=**}/employees/{empId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ── «Код заведения» → cafeId (xodim kirishi) ──
    match /cafeCodes/{code} {
      allow read: if true;
      allow create: if signedIn() &&
        get(/databases/$(database)/documents/cafes/$(request.resource.data.cafeId)).data.ownerUid == request.auth.uid;
      allow update: if signedIn() &&
        get(/databases/$(database)/documents/cafes/$(resource.data.cafeId)).data.ownerUid == request.auth.uid &&
        get(/databases/$(database)/documents/cafes/$(request.resource.data.cafeId)).data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    // ── cafes ──
    match /cafes/{cafeId} {
      allow read: if signedIn() &&
        (resource.data.ownerUid == request.auth.uid || isMember(cafeId));
      // 1.0.8: yangi kafe (1.0.8 ilova) server-vaqtli `createdAt` bilan
      // yaratiladi — sinov shundan hisoblanadi, kalendar firibi o'tmaydi.
      // ORQAGA MOSLIK: Play'dagi eski (1.0.7) ilova `createdAt` yubormaydi —
      // uni RAD ETSAK eski ilovada ro'yxatdan o'tish buziladi. Shuning uchun
      // `createdAt` yo YO'Q (eski ilova → legacy-istisno bilan ishlaydi,
      // keyin migratsiya qilinadi), YOKI aynan server vaqti (yangi ilova).
      // Ikkala holatda ham paidUntil/trialUntil ni mijoz qo'yib ololmaydi.
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid
        && (!('createdAt' in request.resource.data)
            || request.resource.data.createdAt == request.time)
        && !('paidUntil' in request.resource.data)
        && !('trialUntil' in request.resource.data);
      // `ownerUid` — tenant takeover'ga qarshi muzlatilgan.
      // `subscription`/`trialEndsAt`/`paidUntil`/`trialUntil`/`createdAt` —
      // faqat server (Admin SDK): mijoz obunani o'zi uzaytira olmasin.
      allow update: if canManage(cafeId)
        && unchanged(['ownerUid', 'subscription', 'trialEndsAt', 'paidUntil', 'trialUntil', 'createdAt'])
        && (unchanged(['code']) || codeAssignable());
      allow delete: if isOwner(cafeId);

      // ── employees ──
      match /employees/{empId} {
        allow read: if isMember(cafeId) || isOwner(cafeId);
        allow create, delete: if canManage(cafeId);
        // Y-2: sotuvchi O'Z hujjatida revenue/checks ni faqat OSHIRA oladi;
        // role/active/uid/login muzlatiladi.
        allow update: if canManage(cafeId)
          || (request.auth.uid == empId
              && request.resource.data.role == resource.data.role
              && request.resource.data.active == resource.data.active
              && request.resource.data.revenue >= resource.data.revenue
              && request.resource.data.checks >= resource.data.checks
              && unchanged(['uid', 'login']));
      }

      // ── Menyu (menu) ──
      match /categories/{id} {
        allow read: if isMember(cafeId);
        allow write: if canMenu(cafeId);
      }
      match /products/{id} {
        allow read: if isMember(cafeId);
        allow write: if canMenu(cafeId);
      }

      // ── Ombor (sklad) ──
      match /ingredients/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId) || canSell(cafeId);
      }
      match /suppliers/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /supplies/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /storages/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /wastes/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /inventories/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /processings/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }

      // ── Moliya (finance) ──
      match /accounts/{id} {
        allow read: if isMember(cafeId);
        allow create, delete: if canFinance(cafeId);
        allow update: if canFinance(cafeId) || canSell(cafeId);
      }
      match /transactions/{id} {
        allow read: if isMember(cafeId);
        // KR-6: summa tipi tekshiriladi. 1.0.8: obuna tugagan bo'lsa yangi
        // moliyaviy yozuvlar ham to'xtaydi (subActive).
        allow create: if (canFinance(cafeId) || canSell(cafeId))
          && request.resource.data.amount is number
          && subActive(cafeId);
        allow update, delete: if canFinance(cafeId);
      }

      // ── Marketing / mijozlar ──
      match /clients/{id} {
        allow read: if isMember(cafeId);
        allow write: if canMarket(cafeId);
      }
      match /clientGroups/{id} {
        allow read: if isMember(cafeId);
        allow write: if canManage(cafeId) || hasRole(cafeId, ['Маркетолог']);
      }
      match /promotions/{id} {
        allow read: if isMember(cafeId);
        allow write: if canManage(cafeId) || hasRole(cafeId, ['Маркетолог']);
      }

      // ── Kassa: cheklar ──
      match /receipts/{id} {
        allow read: if isMember(cafeId);
        // 1.0.8 OBUNA GATE: muddat o'tgan — yangi chek YOZILMAYDI (qattiq blok).
        allow create: if canSell(cafeId) && subActive(cafeId);
        // Y-11/M3: sotuvchi faqat `status`ni o'zgartira oladi.
        allow update: if canManage(cafeId)
          || (canSell(cafeId)
              && request.resource.data.sum == resource.data.sum
              && request.resource.data.items == resource.data.items
              && request.resource.data.profit == resource.data.profit
              && request.resource.data.id == resource.data.id);
        allow delete: if canManage(cafeId);
      }

      // ── Kassa: ochiq cheklar (stollardagi buyurtmalar) ──
      match /openChecks/{id} {
        allow read: if isMember(cafeId);
        // 1.0.8: yangi buyurtma yozish/tahrirlash — faqat obuna faol bo'lsa.
        // delete OCHIQ qoladi: eski cheklarni yopish/tozalash bloklanmasin.
        allow create, update: if (canSell(cafeId) || canManage(cafeId)) && subActive(cafeId);
        allow delete: if canSell(cafeId) || canManage(cafeId);
      }

      // ── Kassa: «Закрыть без оплаты» audit jurnali (№5) ──
      match /voidedChecks/{id} {
        allow read: if canManage(cafeId);
        allow create: if canSell(cafeId) || canManage(cafeId);
        allow update, delete: if false;
      }

      // ── Kassa: smenalar (Кассовая смена / Z-отчёт) ──
      match /shifts/{id} {
        allow read: if isMember(cafeId);
        // 1.0.8: yangi smena/smena yangilash — faqat obuna faol bo'lsa.
        allow create, update: if (canSell(cafeId) || canManage(cafeId)) && subActive(cafeId);
        allow delete: if false;
      }

      // ── Zallar / stollar ──
      match /halls/{id} {
        allow read: if isMember(cafeId);
        allow write: if canManage(cafeId);
      }
      match /tables/{id} {
        allow read: if isMember(cafeId);
        allow write: if canManage(cafeId) || canSell(cafeId);
      }

      // ── Statistika (Cloud Function yozadi; mijoz o'qiydi) ──
      match /stats/{date} {
        allow read: if isMember(cafeId);
        allow write: if false; // faqat Admin SDK (Cloud Function)
      }

      // Boshqa kutilmagan subkolleksiya — rad etiladi.
      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
}
