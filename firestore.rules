rules_version = '2';

// Buxoro POS вАФ RBAC Security Rules (BACKEND-TAYYORGARLIK.md ¬І3, ¬І9, ¬І12).
// Multi-tenant: owners/{uid}, cafes/{cafeId}, cafes/{cafeId}/{employees,...}.
// Rollar (¬І3): –Т–ї–∞–і–µ–ї–µ—Ж, –£–њ—А–∞–≤–ї—П—О—Й–Є–є, –Р–і–Љ–Є–љ–Є—Б—В—А–∞—В–Њ—А –Ј–∞–ї–∞, –Ю—Д–Є—Ж–Є–∞–љ—В, –Я–Њ–≤–∞—А, –Ь–∞—А–Ї–µ—В–Њ–ї–Њ–≥.
service cloud.firestore {
  match /databases/{database}/documents {

    // вФАвФА Yordamchi funksiyalar вФАвФА
    function signedIn() {
      return request.auth != null;
    }
    function cafeDoc(cafeId) {
      return get(/databases/$(database)/documents/cafes/$(cafeId)).data;
    }
    function isOwner(cafeId) {
      return signedIn() && cafeDoc(cafeId).ownerUid == request.auth.uid;
    }
    function isMember(cafeId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/cafes/$(cafeId)/employees/$(request.auth.uid));
    }
    function role(cafeId) {
      return get(/databases/$(database)/documents/cafes/$(cafeId)/employees/$(request.auth.uid)).data.role;
    }
    function hasRole(cafeId, roles) {
      return isMember(cafeId) && (role(cafeId) in roles);
    }
    // Modul-darajali yozuv huquqlari (¬І3 rolePermissions).
    function canManage(cafeId) { // owner + –£–њ—А–∞–≤–ї—П—О—Й–Є–є (deyarli 'all')
      return isOwner(cafeId) || hasRole(cafeId, ['–£–њ—А–∞–≤–ї—П—О—Й–Є–є']);
    }
    function canMenu(cafeId) {    // menu: owner, manager, –Я–Њ–≤–∞—А
      return canManage(cafeId) || hasRole(cafeId, ['–Я–Њ–≤–∞—А']);
    }
    function canStock(cafeId) {   // sklad: owner, manager, –Я–Њ–≤–∞—А, –Р–і–Љ–Є–љ–Є—Б—В—А–∞—В–Њ—А –Ј–∞–ї–∞
      return canManage(cafeId) || hasRole(cafeId, ['–Я–Њ–≤–∞—А', '–Р–і–Љ–Є–љ–Є—Б—В—А–∞—В–Њ—А –Ј–∞–ї–∞']);
    }
    function canSell(cafeId) {    // kassa/receipts: owner, manager, hallAdmin, –Ю—Д–Є—Ж–Є–∞–љ—В
      return canManage(cafeId) || hasRole(cafeId, ['–Р–і–Љ–Є–љ–Є—Б—В—А–∞—В–Њ—А –Ј–∞–ї–∞', '–Ю—Д–Є—Ж–Є–∞–љ—В']);
    }
    function canFinance(cafeId) { // finance: owner, manager
      return canManage(cafeId);
    }
    function canMarket(cafeId) {  // marketing/clients: owner, manager, –Ь–∞—А–Ї–µ—В–Њ–ї–Њ–≥, –Ю—Д–Є—Ж–Є–∞–љ—В
      return canManage(cafeId) || hasRole(cafeId, ['–Ь–∞—А–Ї–µ—В–Њ–ї–Њ–≥', '–Ю—Д–Є—Ж–Є–∞–љ—В']);
    }
    // Yangilashda o'zgarmasligi shart bo'lgan maydonlar to'plami.
    function unchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }
    // ¬Ђ–Ъ–Њ–і –Ј–∞–≤–µ–і–µ–љ–Є—П¬ї faqat BIR MARTA (bo'sh bo'lganda) yoziladi.
    // `_assignCafeCode` kafe yaratilgach kodni `set(merge)` bilan qo'yadi вАФ buni
    // to'sib qo'ymaslik kerak; lekin mavjud kodni o'zgartirish taqiqlanadi
    // (aks holda xodimlar kirish kodidan uzilib qolardi).
    function codeAssignable() {
      return !('code' in resource.data)
          || resource.data.code == null
          || resource.data.code == '';
    }

    // вФАвФА owners вФАвФА
    match /owners/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // вФАвФА Collection-group: xodim o'z hujjatini uid bo'yicha topadi (login) вФАвФА
    // resolveContext: collectionGroup('employees').where('uid','==',uid)
    match /{path=**}/employees/{empId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // вФАвФА ¬Ђ–Ъ–Њ–і –Ј–∞–≤–µ–і–µ–љ–Є—П¬ї вЖТ cafeId (xodim kirishi) вФАвФА
    // O'qish ochiq: kod auth'dan OLDIN kerak (sintetik email yasash uchun);
    // kod faqat cafeId'ga ishora qiladi, ma'lumotga kirish bermaydi.
    match /cafeCodes/{code} {
      allow read: if true;
      // `create` вАФ kod bo'sh bo'lsa. `update` вАФ faqat MAVJUD egasi o'zgartira oladi:
      // avval faqat YANGI cafeId tekshirilardi, ya'ni har qanday owner boshqa
      // kafening kodini o'ziga tortib olib, uning xodimlarini kirishdan uzardi.
      allow create: if signedIn() &&
        get(/databases/$(database)/documents/cafes/$(request.resource.data.cafeId)).data.ownerUid == request.auth.uid;
      allow update: if signedIn() &&
        get(/databases/$(database)/documents/cafes/$(resource.data.cafeId)).data.ownerUid == request.auth.uid &&
        get(/databases/$(database)/documents/cafes/$(request.resource.data.cafeId)).data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    // вФАвФА cafes вФАвФА
    match /cafes/{cafeId} {
      // MUHIM: query (where ownerUid==uid) uchun resource.data orqali tekshiriladi вАФ
      // get()-ga asoslangan isOwner() list-so'rovlarda isbotlanmaydi (PERMISSION_DENIED edi).
      allow read: if signedIn() &&
        (resource.data.ownerUid == request.auth.uid || isMember(cafeId));
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      // Konfiguratsiyani owner/manager yangilaydi; o'chirish faqat owner.
      // MUHIM: `ownerUid` yangilashda O'ZGARMAYDI вАФ aks holda –£–њ—А–∞–≤–ї—П—О—Й–Є–є uni
      // o'ziga yozib kafeni tortib olardi (tenant takeover).
      // `subscription`/`trialEndsAt` вАФ faqat server (Admin SDK): mijoz obunani
      // o'zi ¬Ђto'langan¬ї deb belgilay olmasin.
      // `code` вАФ faqat bir marta (bo'sh bo'lganda) yoziladi, keyin muzlaydi.
      allow update: if canManage(cafeId)
        && unchanged(['ownerUid', 'subscription', 'trialEndsAt'])
        && (unchanged(['code']) || codeAssignable());
      allow delete: if isOwner(cafeId);

      // вФАвФА employees вФАвФА
      match /employees/{empId} {
        allow read: if isMember(cafeId) || isOwner(cafeId);
        // Xodim yaratish/o'chirish/rol вАФ Cloud Function (Admin SDK) orqali.
        // Bu yerda: owner/manager to'g'ridan-to'g'ri yozishi mumkin (zaxira yo'l).
        allow create, delete: if canManage(cafeId);
        // Owner/manager to'liq; xodim faqat o'z hujjatini cheklangan yangilaydi.
        // `revenue`/`checks` вАФ xodim o'z statistikasini shishirmasin;
        // `uid`/`login` вАФ o'zgarmas identifikatorlar.
        // Y-2: sotuvchi O'Z hujjatida revenue/checks ni faqat OSHIRA oladi
        // (completePayment batch increment qiladi); role/active/uid/login
        // muzlatiladi. Ilgari revenue/checks umuman o'zgarmas edi вЖТ o'z hisobi
        // (loginByStaffCode) bilan kirgan ofitsiantning butun sotuv batch'i rad
        // etilardi (kassa/sklad/bonus yozilmasdan qolardi).
        allow update: if canManage(cafeId)
          || (request.auth.uid == empId
              && request.resource.data.role == resource.data.role
              && request.resource.data.active == resource.data.active
              && request.resource.data.revenue >= resource.data.revenue
              && request.resource.data.checks >= resource.data.checks
              && unchanged(['uid', 'login']));
      }

      // вФАвФА Menyu (menu) вФАвФА
      match /categories/{id} {
        allow read: if isMember(cafeId);
        allow write: if canMenu(cafeId);
      }
      match /products/{id} {
        allow read: if isMember(cafeId);
        allow write: if canMenu(cafeId);
      }

      // вФАвФА Ombor (sklad) вФАвФА
      match /ingredients/{id} {
        allow read: if isMember(cafeId);
        // Sotuvda qoldiq kamayadi вЖТ sotuvchi ham yozadi; boshqacha вАФ sklad huquqi.
        allow write: if canStock(cafeId) || canSell(cafeId);
      }
      match /suppliers/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /supplies/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /storages/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /wastes/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /inventories/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }
      match /processings/{id} {
        allow read: if isMember(cafeId);
        allow write: if canStock(cafeId);
      }

      // вФАвФА Moliya (finance) вФАвФА
      match /accounts/{id} {
        allow read: if isMember(cafeId);
        // Balans sotuvda ham o'zgaradi (kassa yashigi) вЖТ canSell ham yozadi.
        // Lekin hisobni YARATISH/O'CHIRISH faqat moliya huquqi bilan
        // (ofitsiant kassa yashigini o'chirib izini yashira olmasin).
        allow create, delete: if canFinance(cafeId);
        allow update: if canFinance(cafeId) || canSell(cafeId);
      }
      match /transactions/{id} {
        allow read: if isMember(cafeId);
        // Har bir SOTUV `persistSale` ichida transaction yozuvini yaratadi вАФ
        // shuning uchun `create` sotuvchiga ham ochiq. Aks holda ofitsiant
        // smenasida moliya jurnali jim bo'sh qolardi (PERMISSION_DENIED).
        // Tahrirlash/o'chirish вАФ faqat moliya huquqi.
        // KR-6: eng kamida summa tipini tekshiramiz (buzuq/soxta hujjat kirmasin).
        // To'liq himoya (amount == receipt.sum, balansni faqat server yozishi)
        // server-avtoritar to'lov–љ–Є (CF completePayment) talab qiladi вАФ audit'da qayd.
        allow create: if (canFinance(cafeId) || canSell(cafeId))
          && request.resource.data.amount is number;
        allow update, delete: if canFinance(cafeId);
      }

      // вФАвФА Marketing / mijozlar вФАвФА
      match /clients/{id} {
        allow read: if isMember(cafeId);
        allow write: if canMarket(cafeId);
      }
      match /clientGroups/{id} {
        allow read: if isMember(cafeId);
        allow write: if canManage(cafeId) || hasRole(cafeId, ['–Ь–∞—А–Ї–µ—В–Њ–ї–Њ–≥']);
      }
      match /promotions/{id} {
        allow read: if isMember(cafeId);
        allow write: if canManage(cafeId) || hasRole(cafeId, ['–Ь–∞—А–Ї–µ—В–Њ–ї–Њ–≥']);
      }

      // вФАвФА Kassa: cheklar вФАвФА
      match /receipts/{id} {
        allow read: if isMember(cafeId);
        allow create: if canSell(cafeId);
        // Y-11/M3: sotuvchi vozvrat uchun faqat `status`ni o'zgartira oladi;
        // `sum`/`items`/`profit`/`id` MUZLATILADI вАФ eski chek tahrirlab
        // firibgarlik qilinmasin. To'liq tahrir вАФ faqat menejer.
        allow update: if canManage(cafeId)
          || (canSell(cafeId)
              && request.resource.data.sum == resource.data.sum
              && request.resource.data.items == resource.data.items
              && request.resource.data.profit == resource.data.profit
              && request.resource.data.id == resource.data.id);
        allow delete: if canManage(cafeId);
      }

      // вФАвФА Kassa: ochiq cheklar (stollardagi buyurtmalar) вФАвФА
      // Blok SHART: usiz oxiridagi `match /{document=**}` hamma yozuvni RAD
      // etadi (xato catchError'da jim yutiladi вАФ `shifts` bilan shu bo'lgan).
      match /openChecks/{id} {
        allow read: if isMember(cafeId);
        // To'langan/bekor qilingan chek delete qilinadi вАФ write ichida delete ham bor.
        allow write: if canSell(cafeId) || canManage(cafeId);
      }

      // вФАвФА Kassa: ¬Ђ–Ч–∞–Ї—А—Л—В—М –±–µ–Ј –Њ–њ–ї–∞—В—Л¬ї audit jurnali (вДЦ5) вФАвФА
      // O'ZGARMAS: faqat create вАФ kassir yozadi, hech kim tahrirlay/o'chira
      // olmaydi (aks holda audit ma'nosini yo'qotadi). O'qish вАФ boshqaruvga.
      match /voidedChecks/{id} {
        allow read: if canManage(cafeId);
        allow create: if canSell(cafeId) || canManage(cafeId);
        allow update, delete: if false;
      }

      // вФАвФА Kassa: smenalar (–Ъ–∞—Б—Б–Њ–≤–∞—П —Б–Љ–µ–љ–∞ / Z-–Њ—В—З—С—В) вФАвФА
      // Sotuvchi smenani ochadi/yopadi va har chekda ko'rsatkichlarni oshiradi.
      match /shifts/{id} {
        allow read: if isMember(cafeId);
        allow create, update: if canSell(cafeId) || canManage(cafeId);
        // Yopilgan smenani o'chirish mumkin emas (Z-otchet auditi buzilmasin).
        allow delete: if false;
      }

      // вФАвФА Zallar / stollar вФАвФА
      match /halls/{id} {
        allow read: if isMember(cafeId);
        allow write: if canManage(cafeId);
      }
      match /tables/{id} {
        allow read: if isMember(cafeId);
        allow write: if canManage(cafeId) || canSell(cafeId);
      }

      // вФАвФА Statistika (Cloud Function yozadi; mijoz o'qiydi) вФАвФА
      match /stats/{date} {
        allow read: if isMember(cafeId);
        allow write: if false; // faqat Admin SDK (Cloud Function)
      }

      // Boshqa kutilmagan subkolleksiya вАФ rad etiladi.
      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
}
